{
  "expo": {
    "name": "Smart Parking",
    "slug": "smart-parking-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "package": "com.anonymous.smartparkingmobile"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "auto",
      "apiPort": "8080"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению нужен доступ к галерее, чтобы добавить фото автомобиля.",
          "cameraPermission": "Приложению нужен доступ к камере, чтобы сфотографировать автомобиль."
        }
      ]
    ]
  }
}
